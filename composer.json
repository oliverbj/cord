{
    "name": "oliverbj/cord",
    "description": "Seamless integration to CargoWise One's eAdapter using the HTTP service.",
    "keywords": [
        "oliverbj",
        "laravel",
        "cord"
    ],
    "homepage": "https://github.com/oliverbj/cord",
    "license": "MIT",
    "authors": [
        {
            "name": "Oliver Busk",
            "email": "oliverbusk@hotmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-simplexml": "*",
        "guzzlehttp/guzzle": "^7.4",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/array-to-xml": "^3.1",
        "spatie/laravel-package-tools": "^1.92"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.28",
        "nunomaduro/collision": "^8.9",
        "orchestra/testbench": "^9.16|^10.9",
        "pestphp/pest": "^3.8",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Oliverbj\\Cord\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Oliverbj\\Cord\\Tests\\": "tests"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "manual-staff-test": "php bin/manual-staff-test.php",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Oliverbj\\Cord\\CordServiceProvider"
            ],
            "aliases": {
                "Cord": "Oliverbj\\Cord\\Facades\\Cord"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
